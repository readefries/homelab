apiVersion: v1
kind: Service
metadata:
  name: gotify
  namespace: gotify
  annotations:
    metallb.universe.tf/address-pool: default-pool
spec:
  type: LoadBalancer
  ipFamilyPolicy: PreferDualStack
  ipFamilies:
  - IPv4
  - IPv6
  selector:
    app: gotify
  ports:
  - port: 80
    targetPort: 80
    protocol: TCP
    name: http
